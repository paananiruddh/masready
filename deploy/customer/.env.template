# ─────────────────────────────────────────────────────────────────────────────
# MASReady — Customer Live Deployment Configuration
# Copy this file to .env and fill in your values before running docker compose.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tenant identity ──────────────────────────────────────────────────────────
# Short slug used in URLs and logs (lowercase, no spaces, e.g. "transurban")
TENANT_SLUG=your-org

# Display name shown in the UI
TENANT_NAME=Your Organisation

# ── Maximo / IBM MAS connection ───────────────────────────────────────────────
# Full base URL of your Maximo instance (no trailing slash)
MAXIMO_BASE_URL=https://maximo.your-org.com

# Authentication mode: "apikey" (Maximo 7.6.x) or "oauth2" (IBM MAS 9.x)
MAXIMO_AUTH_MODE=apikey

# ── Option A: API key auth (Maximo 7.6.x / MAS Manage with API key enabled) ──
MAXIMO_API_KEY=

# ── Option B: OAuth2 client credentials (IBM MAS 9.x) ────────────────────────
# Leave blank if using apikey above
MAXIMO_TOKEN_URL=https://auth.your-org.com/oidc/endpoint/MaximoAppSuite/token
MAXIMO_CLIENT_ID=
MAXIMO_CLIENT_SECRET=

# ── Database (internal — change the password) ─────────────────────────────────
POSTGRES_DB=masready
POSTGRES_USER=masready
POSTGRES_PASSWORD=change-this-password
DATABASE_URL=postgresql://masready:change-this-password@db:5432/masready

# ── API server ────────────────────────────────────────────────────────────────
PORT=8080
LOG_LEVEL=info

# ── Optional: email (contact form) ───────────────────────────────────────────
# Only needed if the contact form is enabled
BREVO_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
