# MASReady — required environment variables
# Copy to .env for local development. Never commit .env to version control.

# ── Brevo transactional email (required for contact form) ──────────────────
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key

# Optional: Brevo SMTP relay credentials (alternative to API key)
# Use SMTP key from: https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your-brevo-login-email
BREVO_SMTP_PASS=your-brevo-smtp-key

# ── Contact form routing ───────────────────────────────────────────────────
# Where form submission notifications are delivered
CONTACT_TO_EMAIL=hello@masready.com.au
# Sender address shown on notification emails (must be a verified Brevo sender)
CONTACT_FROM_EMAIL=no-reply@masready.com.au
